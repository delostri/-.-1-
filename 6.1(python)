import pandas as pd

file = "data.xlsx"

# читаем лист продажи
df_sales = pd.read_excel(file, sheet_name="Продажи")
print("первые 5 строк продаж:")
print(df_sales.head())

# используем столбец дата как индекс при чтении затрат
df_costs = pd.read_excel(file, sheet_name="Затраты", index_col=0)
print("\nзатраты с датой в индексе:")
print(df_costs.head())

# фильтрация: продажи после 02.01.2024
df_sales['Дата'] = pd.to_datetime(df_sales['Дата'], format='%d.%m.%Y')
filtered = df_sales[df_sales['Дата'] > '2024-01-02']
print("\nпродажи после 02.01.2024:")
print(filtered)

# группировка продаж по месяцам (если данных много, для примера добавим месяц)
df_sales['Месяц'] = df_sales['Дата'].dt.month_name()
monthly = df_sales.groupby('Месяц')['Сумма'].sum()
print("\nсумма продаж по месяцам:")
print(monthly)

# читаем все листы сразу
all = pd.read_excel(file, sheet_name=None)
for name, sheet in all.items():
    print(f"\nлист {name}: {sheet.shape[0]} строк")
